	<parameter name="logo" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String"/>
	<parameter name="beginDate" class="java.lang.String"/>
	<parameter name="endDate" class="java.lang.String"/>
	<parameter name="applointmentClause" class="java.lang.String"/>
	<queryString language="SQL">
		<![CDATA[SELECT DISTINCT users.USER_ID,
                users.FULL_NAME,
                CL.SYS_ID, 
                CL.CLIENT_NO, 
                CL.NAME, 
                CL.MOBILE, 
                CL.EMAIL,
                AP.CREATION_TIME,
                AP.APPOINTMENT_DATE,
                AP.CURRENT_STATUS_SINCE,
                ST.CASE_AR,
                ST.CASE_EN,
                AP.OPTION9,
                Ap.Note,
                AP.OPTION8,
                AP.CALL_DURATION,
                AP."COMMENT"
FROM   CLIENT CL INNER JOIN APPOINTMENT AP ON CL.SYS_ID = AP.CLIENT_ID 
                 LEFT JOIN CLIENT_RATING CR ON CL.SYS_ID = CR.CLIENT_ID 
                 INNER JOIN users on users.user_id = AP.APPOINTMENT_FOR
                 LEFT JOIN STATUS_TYPE ST ON AP.CURRENT_STATUS = ST.ID 
WHERE  $P!{applointmentClause}
ORDER BY users.USER_ID,CL.SYS_ID]]>
	</queryString>
	<field name="USER_ID" class="java.lang.String"/>
	<field name="FULL_NAME" class="java.lang.String"/>
	<field name="SYS_ID" class="java.lang.String"/>
	<field name="CLIENT_NO" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="MOBILE" class="java.lang.String"/>
	<field name="EMAIL" class="java.lang.String"/>
	<field name="CREATION_TIME" class="java.sql.Date"/>
	<field name="APPOINTMENT_DATE" class="java.sql.Date"/>
	<field name="CURRENT_STATUS_SINCE" class="java.sql.Date"/>
	<field name="CASE_AR" class="java.lang.String"/>
	<field name="CASE_EN" class="java.lang.String"/>
	<field name="OPTION9" class="java.lang.String"/>
	<field name="NOTE" class="java.lang.String"/>
	<field name="OPTION8" class="java.lang.String"/>
	<field name="CALL_DURATION" class="java.math.BigDecimal"/>
	<field name="COMMENT" class="java.lang.String"/>
