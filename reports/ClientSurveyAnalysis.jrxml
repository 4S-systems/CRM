	</parameter>
	<parameter name="logo" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[select sys_id, name, mobile, project_id, project_name, rate, case when (rate in (1,2)) then 1 when (rate = 3) then 2 Else 3 end As simple_rate 
from client_survey inner join project on client_survey.question_id = project.project_id 
                   inner join client on client_survey.client_id = client.sys_id 
where TRUNC(client_survey.CREATION_TIME) BETWEEN '01-JAN-2018' AND '31-Dec-2018'
group by sys_id, name, mobile, project_id, project_name, rate
order by sys_id, project_id]]>
	</queryString>
	<field name="SYS_ID" class="java.lang.String"/>
	<field name="NAME" class="java.lang.String"/>
	<field name="MOBILE" class="java.lang.String"/>
	<field name="PROJECT_ID" class="java.lang.String"/>
	<field name="PROJECT_NAME" class="java.lang.String"/>
	<field name="RATE" class="java.math.BigDecimal"/>
	<field name="SIMPLE_RATE" class="java.lang.String"/>
