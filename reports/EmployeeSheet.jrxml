	<parameter name="whereClause" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String"/>
	<parameter name="logo" class="java.lang.String"/>
	<queryString>
		<![CDATA[select EMP_NO,EMP_NAME,ADDRESS,HOME_PHONE,EMAIL,dept.PROJECT_NAME As dept ,HOURE_SALARY,NOTE,GENDER,MARITAL_STATUS,SOCIAL_NUMBER ,WORK_START_DATE,MELATRY_STATUS,INSURANCE_NUMBER,BIRTH_DATE,EDUCATION, position.project_name as position , IMAGE 
from Employee inner join issue_Document on Employee.EMP_ID = issue_Document.BUSINESS_OBJ_ID 
              inner join ISSUE_DOCUMENT_DATA on issue_Document.Document_ID = ISSUE_DOCUMENT_DATA.document_id 
              inner join project dept on Employee.DEPARTMENT = dept.PROJECT_ID
              inner join project position on Employee.POSITION = position.PROJECT_ID
WHERE $P!{whereClause}]]>
	</queryString>
