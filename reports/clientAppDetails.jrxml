	<parameter name="logo" class="java.lang.String" isForPrompting="false"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String"/>
	<parameter name="empName" class="java.lang.String"/>
	<parameter name="beginDate" class="java.lang.String"/>
	<parameter name="endDate" class="java.lang.String"/>
	<parameter name="user_id" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="applointmentClause" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[SELECT CLIENT_ID,
       MOBILE, 
       PHONE, 
       CLIENT_NAME, 
       CREATION_TIME, 
       APPOINTMENT_DATE, 
       OPTION9, 
       Note, 
       abs(round(cast(APPOINTMENT_DATE as Date)- cast(CREATION_TIME as Date),0)) as duration, 
       "COMMENT", 
       CURRENT_STATUS, 
       APPOINTMENT_PLACE, 
       CALL_DURATION 
FROM   APPOINTMENT_NOTIFICATION 
WHERE  $P!{applointmentClause}
ORDER BY CLIENT_NAME, CREATION_TIME]]>
	</queryString>
	<field name="CLIENT_ID" class="java.lang.String"/>
	<field name="MOBILE" class="java.lang.String"/>
	<field name="PHONE" class="java.lang.String"/>
	<field name="CLIENT_NAME" class="java.lang.String"/>
	<field name="CREATION_TIME" class="oracle.sql.TIMESTAMP"/>
	<field name="APPOINTMENT_DATE" class="oracle.sql.TIMESTAMP"/>
	<field name="OPTION9" class="java.lang.String"/>
	<field name="NOTE" class="java.lang.String"/>
	<field name="DURATION" class="java.math.BigDecimal"/>
	<field name="COMMENT" class="java.lang.String"/>
	<field name="CURRENT_STATUS" class="java.lang.String"/>
	<field name="APPOINTMENT_PLACE" class="java.lang.String"/>
	<field name="CALL_DURATION" class="java.math.BigDecimal"/>
