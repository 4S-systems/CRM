	<property name="ireport.y" value="0"/>
	<parameter name="ID" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/home/yasmin/projects/src/crm/reports/"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select issue.id, issue.BUSINESS_ID, issue.BUSINESS_ID_BY_DATE, issue.USER_ID, issue.CURRENT_STATUS, status_type.CASE_AR, issue.CREATION_TIME, 
       issue_project.PROJECT_ID, issue_project.OPTION2,
       request_items.PROJECT_ID as spare_id, request_items.QUANTITY,
       project.PROJECT_NAME, users.user_name
from issue inner join issue_project on issue.ID = issue_project.ISSUE_ID 
           inner join request_items on issue.ID = request_items.issue_id
           inner join project on request_items.PROJECT_ID = project.PROJECT_ID
           inner join status_type on issue.CURRENT_STATUS = status_type.ID
           inner join users on issue.USER_ID = users.user_id
where issue.id = $P{ID}]]>
	</queryString>
	<field name="ID" class="java.lang.String"/>
	<field name="BUSINESS_ID" class="java.lang.String"/>
	<field name="BUSINESS_ID_BY_DATE" class="java.lang.String"/>
	<field name="USER_ID" class="java.lang.String"/>
	<field name="CURRENT_STATUS" class="java.lang.String"/>
