	<field name="SPARE_ID" class="java.lang.String"/>
	<field name="QUANTITY" class="java.lang.String"/>
	<field name="PROJECT_NAME" class="java.lang.String"/>
	<field name="USER_NAME" class="java.lang.String"/>
