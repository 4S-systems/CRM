	<parameter name="logo" class="java.lang.String"/>
	<parameter name="unit_name" class="java.lang.String"/>
	<parameter name="job_no" class="java.lang.String"/>
	<queryString>
		<![CDATA[select LABOR_COMPLAINT.REASON as com,ISSUE_TASKS_COMPALINTS.EXCTION_INSTRCT as des,TASKS.TASK_NAME as task from LABOR_COMPLAINT , ISSUE_TASKS_COMPALINTS,TASKS  Where   LABOR_COMPLAINT.ID=ISSUE_TASKS_COMPALINTS.COMPLAIN_ID and TASKS.ID=ISSUE_TASKS_COMPALINTS.TASK_ID and ISSUE_TASKS_COMPALINTS.ISSUE_ID=$P{issue_id} order by com]]>
	</queryString>
	<field name="COM" class="java.lang.String"/>
	<field name="task" class="java.lang.String"/>
	<field name="DES" class="java.lang.String"/>
	<group name="g1">
		<groupExpression><![CDATA[$F{COM}]]></groupExpression>
		<groupHeader>
			<band height="30">
				<textField pattern="" isBlankWhenNull="false">
