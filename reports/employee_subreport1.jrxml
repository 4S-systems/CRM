<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="employee_subreport1" pageWidth="555" pageHeight="802" columnWidth="555" leftMargin="0" rightMargin="0" topMargin="0" bottomMargin="0" uuid="d4944c65-f45c-45dd-9a7b-5ab2d5e88d1a">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="mgr" class="java.lang.String">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select ss.full_name,dd.project_name,ssss.full_name as emp_name,sss.group_name
from emp_mgr em
left join users ss on em.mgr_id = ss.user_id
left join project dd on em.mgr_id = dd.option_one and dd.location_type = 'div'
left join user_group sss on em.emp_id = sss.user_id
left join users ssss on sss.user_id = ssss.user_id
where em.mgr_id <> 1
and ( ss.full_name = $P{mgr} or $P{mgr} is null )
order by ss.full_name]]>
	</queryString>
	<field name="FULL_NAME" class="java.lang.String"/>
	<field name="PROJECT_NAME" class="java.lang.String"/>
	<field name="EMP_NAME" class="java.lang.String"/>
	<field name="GROUP_NAME" class="java.lang.String"/>
	<detail>
		<band height="23" splitType="Stretch">
			<textField>
				<reportElement mode="Opaque" x="422" y="4" width="133" height="19" backcolor="#FFFFCC" uuid="29591d4e-cce7-4538-bb42-58725804d253"/>
				<box>
					<topPen lineWidth="1.0"/>
					<leftPen lineWidth="1.0"/>
					<bottomPen lineWidth="1.0"/>
					<rightPen lineWidth="1.0"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Arial" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{GROUP_NAME}]]></textFieldExpression>
			</textField>
			<textField>
				<reportElement mode="Opaque" x="217" y="4" width="205" height="19" backcolor="#FFFFCC" uuid="bebe8248-6f8c-4570-b459-fc2de355bde5"/>
				<box>
					<topPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<leftPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<bottomPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
					<rightPen lineWidth="1.0" lineStyle="Solid" lineColor="#000000"/>
				</box>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Arial" isBold="true"/>
				</textElement>
				<textFieldExpression><![CDATA[$F{EMP_NAME}]]></textFieldExpression>
			</textField>
		</band>
	</detail>
</jasperReport>
