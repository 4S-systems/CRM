	<style name="Crosstab Data Text" hAlign="Center"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["/home/yasmin/projects/src/crm/reports/"]]></defaultValueExpression>
	</parameter>
	<parameter name="logo" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[select  project.PROJECT_NAME , rating.FULL_NAME , rating.CLIENT_ID
from project full join (select users.FULL_NAME, Client_rating.CLIENT_ID, Client_rating.RATE_ID
                        from users inner join user_group on users.USER_ID = user_group.USER_ID 
                        left join Client_rating on users.USER_ID = Client_rating.CREATED_BY
                        where user_group.GROUP_ID = '1408016478381') rating on project.PROJECT_ID = rating.RATE_ID
where project.MAIN_PROJ_ID = '1484491028701' or project.PROJECT_ID is null]]>
	</queryString>
	<field name="PROJECT_NAME" class="java.lang.String"/>
	<field name="FULL_NAME" class="java.lang.String"/>
	<field name="CLIENT_ID" class="java.lang.String"/>
