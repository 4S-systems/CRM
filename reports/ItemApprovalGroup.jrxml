					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Arial" size="10" isBold="true" pdfEncoding="Cp1256"/>
					</textElement>
					<text><![CDATA[اسم البند  ]]></text>
				</staticText>
				<staticText>
					<reportElement mode="Opaque" x="172" y="23" width="176" height="18" backcolor="#CCCCCC"/>
					<box>
						<pen lineWidth="1.25"/>
						<topPen lineWidth="0.75"/>
						<leftPen lineWidth="0.75"/>
						<bottomPen lineWidth="0.75"/>
						<rightPen lineWidth="0.75"/>
					</box>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Arial" size="10" isBold="true" pdfEncoding="Cp1256"/>
					</textElement>
					<text><![CDATA[كود البند  ]]></text>
				</staticText>
				<textField isBlankWhenNull="true">
					<reportElement mode="Opaque" x="114" y="0" width="441" height="13" backcolor="#E6E6FA"/>
					<box rightPadding="10"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="Arial" size="10" isBold="false"/>
					</textElement>
					<textFieldExpression><![CDATA["\u0645\u0627\u0631\u0643\u0629 \u0627\u0644\u0628\u0646\u062F : " + $F{UNIT_NAME}]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
		<groupFooter>
			<band height="29"/>
		</groupFooter>
	</group>
	<background>
