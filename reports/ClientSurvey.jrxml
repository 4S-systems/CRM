	<queryString>
		<![CDATA[select sys_id, name, mobile, project_id, project_name, rate, case when (rate in (1,2)) then 1 when (rate = 3) then 2 Else 3 end As simple_rate 
from client_survey inner join project on client_survey.question_id = project.project_id 
                   inner join client on client_survey.client_id = client.sys_id 
where TRUNC(client_survey.CREATION_TIME)between to_date($P{beginDate},'yyyy/MM/dd') and to_date($P{endDate},'yyyy/MM/dd')
group by sys_id, name, mobile, project_id, project_name, rate
order by sys_id, project_id]]>
	</queryString>
