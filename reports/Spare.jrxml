	<parameter name="logo" class="java.lang.String" isForPrompting="false"/>
	<parameter name="bDate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="eDate" class="java.lang.String" isForPrompting="false"/>
	<parameter name="unitName" class="java.lang.String" isForPrompting="false"/>
	<parameter name="unit_id" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA[]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select count(task_id),tasks.task_name from ALL_MAINTENANCE_INFO
inner join tasks on ALL_MAINTENANCE_INFO.TASK_ID = tasks.ID
where unit_id=$P{unit_id} and EXPECTED_B_DATE between to_date($P{bDate},'yyyy/MM/dd') and to_date($P{eDate},'yyyy/MM/dd')
and task_id is not null
group by task_id , task_name]]>
	</queryString>
	<field name="COUNT(TASK_ID)" class="java.math.BigDecimal"/>
	<field name="TASK_NAME" class="java.lang.String"/>
