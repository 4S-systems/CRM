					<font fontName="Arial" size="12" isBold="true"/>
				</textElement>
				<text><![CDATA[RPT-EQP-SITE-6   ]]></text>
			</staticText>
			<textField isStretchWithOverflow="true" pattern="EEEEE dd MMMMM yyyy / h:mm a">
				<reportElement x="0" y="0" width="232" height="20"/>
				<textElement textAlignment="Left" verticalAlignment="Middle"/>
				<textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
			</textField>
			<line>
				<reportElement x="2" y="20" width="550" height="1"/>
				<graphicElement>
					<pen lineWidth="4.0"/>
				</graphicElement>
			</line>
			<staticText>
				<reportElement mode="Opaque" x="177" y="25" width="267" height="28" backcolor="#E6E6FA"/>
				<textElement textAlignment="Center" verticalAlignment="Middle">
					<font fontName="Arial" size="22" isBold="true" pdfEncoding="Cp1256"/>
				</textElement>
				<text><![CDATA[عرض المعدات حسب الموقع ]]></text>
			</staticText>
			<image scaleImage="FillFrame">
				<reportElement mode="Transparent" x="3" y="44" width="111" height="115"/>
				<imageExpression><![CDATA[$P{logo}]]></imageExpression>
			</image>
		</band>
	</title>
	<pageHeader>
		<band height="23">
			<printWhenExpression><![CDATA[$V{PAGE_NUMBER}!=1]]></printWhenExpression>
			<line>
				<reportElement x="2" y="21" width="550" height="1"/>
				<graphicElement>
