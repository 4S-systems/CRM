<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="Approval" columnDirection="RTL" pageWidth="595" pageHeight="842" whenNoDataType="NoDataSection" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="logo" class="java.lang.String" isForPrompting="false"/>
	<queryString>
		<![CDATA[select  maint.id ,maint.unit_name
,maint.parent_id,maint.unit_no ,main.type_name , maint2.unit_name brand_name , maint.site , proj.project_name
 from MAINTAINABLE_UNIT maint
 inner join MAINTAINABLE_UNIT_TYPE main
 on main.id=maint.main_type_id
 inner join  MAINTAINABLE_UNIT maint2 on maint2.id= maint.parent_id
 inner join project proj on proj.project_id= maint.site
order by maint.site]]>
	</queryString>
	<field name="UNIT_NAME" class="java.lang.String"/>
	<field name="TYPE_NAME" class="java.lang.String"/>
	<field name="UNIT_NO" class="java.lang.String"/>
	<field name="BRAND_NAME" class="java.lang.String"/>
	<field name="PARENT_ID" class="java.lang.String"/>
	<field name="SITE" class="java.lang.String"/>
	<field name="project_name" class="java.lang.String"/>
	<group name="brand_group">
		<groupExpression><![CDATA[$F{SITE}]]></groupExpression>
		<groupHeader>
			<band height="41">
				<staticText>
					<reportElement mode="Opaque" x="524" y="23" width="31" height="18" backcolor="#CCCCCC"/>
					<box>
						<pen lineWidth="1.25"/>
						<topPen lineWidth="0.75"/>
						<leftPen lineWidth="0.75"/>
						<bottomPen lineWidth="0.75"/>
						<rightPen lineWidth="0.75"/>
					</box>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Arial" size="10" isBold="true" pdfEncoding="Cp1256"/>
					</textElement>
					<text><![CDATA[م ]]></text>
				</staticText>
				<staticText>
					<reportElement mode="Opaque" x="400" y="23" width="124" height="18" backcolor="#CCCCCC"/>
					<box>
						<pen lineWidth="1.25"/>
						<topPen lineWidth="0.75"/>
						<leftPen lineWidth="0.75"/>
						<bottomPen lineWidth="0.75"/>
						<rightPen lineWidth="0.75"/>
					</box>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Arial" size="10" isBold="true" pdfEncoding="Cp1256"/>
					</textElement>
					<text><![CDATA[اسم المعده ]]></text>
				</staticText>
				<staticText>
					<reportElement mode="Opaque" x="203" y="23" width="97" height="18" backcolor="#CCCCCC"/>
					<box>
						<pen lineWidth="1.25"/>
						<topPen lineWidth="0.75"/>
						<leftPen lineWidth="0.75"/>
						<bottomPen lineWidth="0.75"/>
						<rightPen lineWidth="0.75"/>
					</box>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Arial" size="10" isBold="true" pdfEncoding="Cp1256"/>
					</textElement>
					<text><![CDATA[النوع الاساسي]]></text>
				</staticText>
				<staticText>
					<reportElement mode="Opaque" x="300" y="23" width="100" height="18" backcolor="#CCCCCC"/>
					<box>
						<pen lineWidth="1.25"/>
						<topPen lineWidth="0.75"/>
						<leftPen lineWidth="0.75"/>
						<bottomPen lineWidth="0.75"/>
						<rightPen lineWidth="0.75"/>
					</box>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Arial" size="10" isBold="true" pdfEncoding="Cp1256"/>
					</textElement>
					<text><![CDATA[كود المعده ]]></text>
				</staticText>
				<staticText>
					<reportElement mode="Opaque" x="90" y="23" width="113" height="18" backcolor="#CCCCCC"/>
					<box>
						<pen lineWidth="1.25"/>
						<topPen lineWidth="0.75"/>
						<leftPen lineWidth="0.75"/>
						<bottomPen lineWidth="0.75"/>
						<rightPen lineWidth="0.75"/>
					</box>
					<textElement textAlignment="Center" verticalAlignment="Middle">
						<font fontName="Arial" size="10" isBold="true" pdfEncoding="Cp1256"/>
					</textElement>
					<text><![CDATA[ماركه/موديل/سنة التصنيع ]]></text>
				</staticText>
				<textField isBlankWhenNull="true">
					<reportElement mode="Opaque" x="114" y="0" width="441" height="13" backcolor="#E6E6FA"/>
					<box rightPadding="10"/>
					<textElement textAlignment="Right" verticalAlignment="Middle">
						<font fontName="Arial" size="10" isBold="false"/>
					</textElement>
					<textFieldExpression><![CDATA["\u0627\u0633\u0645 \u0627\u0644\u0645\u0648\u0642\u0639   : " + $F{project_name}]]></textFieldExpression>
				</textField>
			</band>
		</groupHeader>
		<groupFooter>
			<band height="29"/>
		</groupFooter>
	</group>
	<background>
