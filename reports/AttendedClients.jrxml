	<queryString>
		<![CDATA[SELECT CL.NAME, 
       CL.SYS_ID, 
       CL.MOBILE, 
       CL.CREATION_TIME,
       AP.APPOINTMENT_DATE, 
       AP.APPOINTMENT_PLACE, 
       AP."COMMENT" 
FROM   CLIENT CL INNER JOIN APPOINTMENT AP on CL.SYS_ID = AP.CLIENT_ID 
WHERE $P!{whereClause}]]>
	</queryString>
