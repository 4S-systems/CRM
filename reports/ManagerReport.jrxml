<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd" name="ManagerReport" pageWidth="595" pageHeight="842" columnWidth="535" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20" uuid="8365dcba-ced2-477e-898f-9cecddc6ad3d">
	<property name="ireport.zoom" value="1.0"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="logo" class="java.lang.String"/>
	<queryString>
		<![CDATA[SELECT Manager.USER_NAME as Manager_Name ,PROJECT.PROJECT_NAME  ,Employee.USER_NAME as Employee_Name ,
LISTAGG(USER_GROUP.GROUP_NAME, ', ') WITHIN GROUP (ORDER BY USER_GROUP.GROUP_NAME) "Groups" 
FROM USERS Manager
INNER JOIN EMP_MGR ON Manager.USER_ID = EMP_MGR.MGR_ID
INNER JOIN USERS Employee ON Employee.USER_ID =EMP_MGR.EMP_ID
INNER JOIN USER_GROUP ON Employee.USER_ID = USER_GROUP.USER_ID 
INNER JOIN PROJECT ON Manager.USER_ID = PROJECT.OPTION_ONE
group by Manager.USER_NAME , Employee.USER_NAME ,PROJECT.PROJECT_NAME]]>
	</queryString>
	<field name="MANAGER_NAME" class="java.lang.String"/>
	<field name="PROJECT_NAME" class="java.lang.String"/>
	<field name="EMPLOYEE_NAME" class="java.lang.String"/>
	<field name="Groups" class="java.lang.String"/>
