	<parameter name="logo" class="java.lang.String" isForPrompting="false"/>
	<parameter name="plan_id" class="java.lang.String"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String"/>
	<queryString>
		<![CDATA[select CLIENT_NO,CLIENT.NAME,MOBILE,PHONE,EMAIL,INTER_PHONE,ADDRESS,NATIONALITY,
       proj.PROJECT_NAME As main_proj,
       project.project_id as project_id ,project.PROJECT_NAME, project.EQ_NO,  
       UNIT_PRICE.MAX_PRICE,
       payment_plan.PAYMNET_AMT, payment_plan.plan_id
from payment_plan  inner join CLIENT on payment_plan.client_id = CLIENT.SYS_ID 
                   inner join project on payment_plan.UNIT_ID = project.PROJECT_ID
                   inner join project proj on proj.project_id = project.MAIN_PROJ_ID
                   inner join UNIT_PRICE on payment_plan.UNIT_ID = UNIT_PRICE.UNIT_ID
where plan_id = $P!{plan_id}]]>
	</queryString>
