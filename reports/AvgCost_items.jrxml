	<variable name="totalPrice" class="java.lang.Double">
		<variableExpression><![CDATA[($F{price} != null) ? (Double.parseDouble($F{price}) * Integer.parseInt($F{itemQuantity})) :
                    0.00]]></variableExpression>
	</variable>
