	</detail>
	<columnFooter>
		<band splitType="Stretch"/>
	</columnFooter>
	<pageFooter>
		<band splitType="Stretch"/>
	</pageFooter>
	<summary>
		<band height="802" splitType="Stretch">
			<bar3DChart>
				<chart>
					<reportElement stretchType="RelativeToTallestObject" x="0" y="0" width="555" height="802" isPrintWhenDetailOverflows="true" backcolor="#CCFFCC">
						<property name="net.sf.jasperreports.export.pdf.tag.td" value="full"/>
					</reportElement>
					<chartTitle position="Top"/>
					<chartSubtitle/>
					<chartLegend position="Right">
						<font fontName="Times New Roman" size="6"/>
					</chartLegend>
				</chart>
				<categoryDataset>
					<categorySeries>
						<seriesExpression><![CDATA[$F{name}]]></seriesExpression>
						<categoryExpression><![CDATA[$F{name}]]></categoryExpression>
						<valueExpression><![CDATA[$F{Count}]]></valueExpression>
						<labelExpression><![CDATA[$F{title}]]></labelExpression>
					</categorySeries>
				</categoryDataset>
				<bar3DPlot xOffset="10.0" yOffset="5.0">
					<plot orientation="Horizontal" foregroundAlpha="1.0" labelRotation="0.0"/>
					<itemLabel/>
					<categoryAxisFormat labelRotation="0.0">
						<axisFormat verticalTickLabels="true">
							<tickLabelFont>
								<font fontName="Times New Roman" size="8" isPdfEmbedded="false"/>
							</tickLabelFont>
						</axisFormat>
					</categoryAxisFormat>
				</bar3DPlot>
