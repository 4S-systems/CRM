	<property name="ireport.zoom" value="1.5"/>
	<property name="ireport.x" value="0"/>
	<property name="ireport.y" value="0"/>
	<parameter name="SUBREPORT_DIR" class="java.lang.String" isForPrompting="false">
		<defaultValueExpression><![CDATA["..\\reports\\"]]></defaultValueExpression>
	</parameter>
	<queryString>
		<![CDATA[select distinct ss.full_name,ug.group_name,dd.project_name,sss.full_name as manager,ddd.project_name name_manager
from users ss
left join project dd on ss.user_id = dd.option_one
left join user_group ug on ss.user_id = ug.user_id
left join user_closure_config ucc on ss.user_id = ucc.user_id
left join users sss on ucc.closure_id = sss.user_id
left join project ddd on sss.user_id = ddd.option_one
where dd.location_type = 'div' and ug.group_name !='Sales'
and ss.user_id not in (select uc.closure_id from user_closure_config uc)
order by ss.full_name]]>
	</queryString>
	<field name="FULL_NAME" class="java.lang.String"/>
	<field name="GROUP_NAME" class="java.lang.String"/>
	<field name="PROJECT_NAME" class="java.lang.String"/>
	<field name="MANAGER" class="java.lang.String"/>
	<field name="NAME_MANAGER" class="java.lang.String"/>
