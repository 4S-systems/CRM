  <tag>
    <name>forward</name>
    <tag-class>com.silkworm.jsptags.ForwardTag</tag-class>
    <body-content>JSP</body-content>
    <description>
      Encodes possible param tags in the body, adds them as a
      query string to the URI defined by the page attribute
      and forwards to the specified page. 
    </description>
        <!-- Forte4J_TLDX:  This comment contains code generation information. Do not delete.
        <tldx>
            <packagename>com.silkworm.jsptags</packagename>
            <extendsSupportClass>TRUE</extendsSupportClass>
