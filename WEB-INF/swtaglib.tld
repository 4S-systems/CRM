<?xml version="1.0" encoding="UTF-8" ?>

<!DOCTYPE taglib
        PUBLIC "-//Sun Microsystems, Inc.//DTD JSP Tag Library 1.2//EN"
        "http://java.sun.com/dtd/web-jsptaglibrary_1_2.dtd">



<taglib>
  <tlib-version>2.0</tlib-version>
  <jsp-version>1.2</jsp-version>
  <short-name>sw</short-name>
  <uri>/WEB-INF/swtaglib.tld</uri>
  <description>
    A tag library to simplify web application development
  </description>

<!--
  This validator is just an example and is not really needed for an
  application that uses the example tag library. It's commented out
  to avoid the JDOM depencency (JDOM is used by the validator).
  <validator>
    <validator-class>com.ora.jsp.tlv.OraTLV</validator-class>
  </validator>
-->

  <tag>
    <name>fileWrite</name>
    <tag-class>com.silkworm.jsptags.FileWriteTag</tag-class>
    <body-content>JSP</body-content>
    <description>
       Writes its body content to the specified file
    </description>
        <!-- Forte4J_TLDX:  This comment contains code generation information. Do not delete.
        <tldx>
            <packagename>com.silkworm.jsptags</packagename>
            <extendsSupportClass>TRUE</extendsSupportClass>
            <supportClass>BodyTagSupport</supportClass>
            <implementsTryCatchFinally>FALSE</implementsTryCatchFinally>
            <findparent>FALSE</findparent>
        </tldx>
        -->

    <attribute>
      <name>fileName</name>
      <required>false</required>
            <rtexprvalue>true</rtexprvalue>
            <type>String</type>
            <!-- Forte4J_TLDX:  This comment contains code generation information. Do not delete.
            <tldx>
                <IsReferenceID>FALSE</IsReferenceID>
                <ReferencesTag>FALSE</ReferencesTag>
                <ReferenceScope>Session</ReferenceScope>
                <ReferencesTagReferentFirst>TRUE</ReferencesTagReferentFirst>
            </tldx>
            -->
    </attribute>
  </tag>

  <tag>
    <name>debug</name>
    <tag-class>com.silkworm.jsptags.DebugTag</tag-class>
    <body-content>empty</body-content>
    <description>
       Writes the specified debug info to the response, System.out or
       the application log file based on the value of the debug
       request parameter
    </description>
        <!-- Forte4J_TLDX:  This comment contains code generation information. Do not delete.
        <tldx>
            <packagename>com.silkworm.jsptags</packagename>
            <extendsSupportClass>TRUE</extendsSupportClass>
